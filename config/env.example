# Copy to .env for docker compose or local export
# Verifier
AGENT_RECEIPTS_VERIFIER_API_KEY=change-me-long-random-secret
AGENT_RECEIPTS_VERIFIER_RATE_LIMIT=120
AGENT_RECEIPTS_REQUIRE_PROVER=0
AGENT_RECEIPTS_MAX_BODY_BYTES=1048576

# Production hardening (fix #1/#3/#4/#5)
# Set AGENT_RECEIPTS_ENV=production to fail closed on soundness escape hatches,
# imply REQUIRE_PROVER, force strict config validation, and require a stable signer.
# AGENT_RECEIPTS_ENV=production
# Reject verifier bundles lacking a validated attested-identity binding:
# AGENT_RECEIPTS_REQUIRE_IDENTITY_BINDING=1
# In-process SCITT /entries transparency log: enable on exactly ONE instance.
# AGENT_RECEIPTS_TRANSPARENCY_SINGLE_WRITER=1

# Managed, stable signing key so replicas share one key_id (fix #1b)
# AGENT_RECEIPTS_REQUIRE_STABLE_SIGNER=1
# AGENT_RECEIPTS_SIGNING_KEY_PATH=/var/run/secrets/agentauth/agent_ed25519.key
# AGENT_RECEIPTS_REQUIRE_KEY_ENCRYPTION=1
# AGENT_RECEIPTS_SIGNING_KEY_PASSWORD=<from-secret-store>
# AGENT_RECEIPTS_TRUSTED_SIGNER_KEY_IDS=<pinned-key-id>

# Shared, durable audit store for horizontal scaling (fix #1a). All replicas MUST
# point at ONE single-writer store; a relative/ephemeral default is refused in prod.
# AGENT_RECEIPTS_AUDIT_DB=/mnt/agentauth-audit/chain.sqlite
# AGENT_RECEIPTS_AUDIT_STORE_ACK=1   # acknowledge single-instance deployment instead

# Agent / partner overrides (optional)
# AGENT_RECEIPTS_MODE=bounded_auto
# AGENT_RECEIPTS_MODEL_HASH=sha256:your-model-v1
# AGENT_RECEIPTS_ORGANIZATION=your-org
# AGENT_RECEIPTS_PRINCIPAL_ID=agent-fraud-01
# AGENT_RECEIPTS_STRICT=1
# AGENT_RECEIPTS_LOG_LEVEL=INFO

# Rust prover (set in Docker automatically)
# AGENT_RECEIPTS_CLI=/usr/local/bin/agent-receipts
